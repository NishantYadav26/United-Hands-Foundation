# Copy this file to `.env` (or set these in Vercel/hosting env settings).
# Never commit real secrets to git.

# ===== Frontend =====
# Preferred frontend API base URL (supports deployed environments like Vercel)
REACT_APP_API_URL=http://localhost:8001
# Backward-compatible fallback
REACT_APP_BACKEND_URL=http://localhost:8001
# If neither is set, frontend falls back to:
# https://united-hands-backend.onrender.com

# ===== Backend =====
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
DB_NAME=test_database
CORS_ORIGINS=*

EMERGENT_LLM_KEY=sk-emergent-xxxxxxxxxxxxxxxx
JWT_SECRET_KEY=change-me-in-production

RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=test_secret_placeholder

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=onboarding@resend.dev
